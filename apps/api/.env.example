# Rensoo API 環境変数の雛形。
# 使い方: このファイルを同じディレクトリに `.env` としてコピーし、値を埋める。
#   cp apps/api/.env.example apps/api/.env
# `.env` は .gitignore 済みでコミットされない。`pnpm --filter api dev` / `start` が
# --env-file-if-exists=.env で自動読み込みする（ファイルが無くても起動は失敗しない）。
# API キーは必ずサーバー側（このファイル）だけで扱い、フロント（apps/web）には置かない。

# --- 必須 ---
# Anthropic Claude の API キー（未設定だと API サーバーは起動時に失敗する）。
ANTHROPIC_API_KEY=

# --- 任意 ---
# 連想生成に使う Claude モデル。未指定なら実装既定（claude-haiku-4-5）を使う。
ASSOCIATION_MODEL=

# CORS 許可オリジン（フロントの URL）。開発では未設定でも起動可（全許可の警告が出る）。
# 本番（NODE_ENV=production）では未設定だと起動失敗（フェイルクローズ）。
WEB_ORIGIN=http://localhost:5173

# 保存・一覧機能（認証必須）を使う場合のみ設定する。両方揃うと保存系が有効化される。
# 未設定ならゲスト利用（連想＋自走展開）のみで動作する。
SUPABASE_URL=
SUPABASE_ANON_KEY=

# API サーバーの待受ポート（未指定なら 8787）。
PORT=8787
