# Rensoo フロント（apps/web）環境変数の雛形。
# 使い方: このファイルを同じディレクトリに `.env` としてコピーし、値を埋める。
#   cp apps/web/.env.example apps/web/.env
# Vite は起動時に apps/web/.env を自動読み込みする（追加設定は不要）。
# ここに置けるのは VITE_ 接頭辞の「公開値」だけ。ビルド成果物に埋め込まれ、ブラウザから見える。
# シークレット（ANTHROPIC_API_KEY 等）は絶対にここへ置かない（サーバー側 apps/api/.env のみ）。

# --- 任意 ---
# API サーバーのベース URL。未設定ならフロントと同一オリジンへ送る。
# フロント(5173)と API(8787)を別ポートで動かす開発では下記を設定する。
VITE_API_BASE_URL=http://localhost:8787

# Supabase プロジェクト URL（公開値）。未設定なら認証は無効化され、ゲスト機能のみ動作する。
VITE_SUPABASE_URL=

# Supabase anon キー（公開可能な公開鍵。シークレットではない）。
# VITE_SUPABASE_URL と揃うとログイン・保存機能が有効化される。
VITE_SUPABASE_ANON_KEY=
